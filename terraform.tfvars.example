# ============================================================
#  terraform.tfvars.example — CDC Data Lakehouse
#
#  Copy this file:
#    cp terraform.tfvars.example terraform.tfvars
#
#  Fill in the two required values below, then run:
#    terraform init
#    terraform apply
#
#  terraform.tfvars is listed in .gitignore — your key paths
#  and profile name will never be committed to the repository.
# ============================================================

# ── Required: SSH key paths ───────────────────────────────────
# Point to an existing SSH key pair on your machine.
# If you don't have one, generate it:
#   ssh-keygen -t ed25519 -C "cdc-lakehouse" -f ~/.ssh/cdc_lakehouse

ssh_public_key_path  = "~/.ssh/id_ed25519.pub"   # or id_rsa.pub
ssh_private_key_path = "~/.ssh/id_ed25519"        # or id_rsa

# ── Credentials (choose one method) ──────────────────────────

# Method A — Environment variables (recommended, no edits needed here):
#   export AWS_ACCESS_KEY_ID="AKIA..."
#   export AWS_SECRET_ACCESS_KEY="wJalr..."
#   Then set: aws_profile = ""
aws_profile = ""

# Method B — Named AWS CLI profile:
#   aws configure --profile cdc-lakehouse
#   Then set: aws_profile = "cdc-lakehouse"
# aws_profile = "cdc-lakehouse"

# Method C — Default profile (~/.aws/credentials [default]):
#   aws configure
#   Then set: aws_profile = "default"   (or just leave the default)
# aws_profile = "default"

# ── Region ───────────────────────────────────────────────────
# Default is eu-west-1 (Ireland). Change to your closest region.
# All regions are valid — no restrictions on trial credits.
aws_region = "eu-west-1"

# ── Instance (do not change unless t3.xlarge is unavailable) ─
# t3.xlarge = 4 vCPU / 16 GB RAM — minimum for this pipeline.
# Alternatives: t3a.xlarge (~10% cheaper), m6i.xlarge (more stable burst)
instance_type = "t3.xlarge"

# ── Disk ─────────────────────────────────────────────────────
# 100 GB is recommended to cache container images between runs.
root_volume_size_gb = 100

# ── SSH access restriction (optional but recommended) ─────────
# Replace with your public IP to prevent SSH exposure to the internet.
# Find your IP: curl -s https://checkip.amazonaws.com
# allowed_ssh_cidr = "203.0.113.10/32"
allowed_ssh_cidr = "0.0.0.0/0"

# ── Resource tagging ─────────────────────────────────────────
project_tag = "cdc-lakehouse"
